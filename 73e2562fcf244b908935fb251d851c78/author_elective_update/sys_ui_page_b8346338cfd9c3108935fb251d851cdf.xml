<?xml version="1.0" encoding="UTF-8"?><record_update table="sys_ui_page">
    <sys_ui_page action="DELETE">
        <category>general</category>
        <client_script/>
        <description>AIROP Export Check Results to CSV</description>
        <direct>false</direct>
        <endpoint>x_snc_airop_assessment_export.do</endpoint>
        <html><![CDATA[<?xml version="1.0" encoding="utf-8" ?>
<j:jelly trim="false" xmlns:j="jelly:core" xmlns:g="glide" xmlns:j2="null" xmlns:g2="null">
<g:evaluate>
    var runId = RP.getParameterValue("sysparm_run_id");
    var generated = RP.getParameterValue("generated");
    var fileName = RP.getParameterValue("file_name") || "";
    var errorMsg = RP.getParameterValue("error_msg") || "";
    var runGr = new GlideRecord("x_snc_airop_assessment_run");
    runGr.get(runId);
    var runNumber = runGr.getValue("number");
    var totalChecks = runGr.getValue("checks_executed") || "0";
</g:evaluate>
<style>
    body { font-family: "Source Sans Pro", Arial, sans-serif; margin: 20px; color: #333; }
    h2 { color: #1a1a1a; margin-bottom: 4px; }
    .info-box { background: #f5f5f5; padding: 14px 18px; border-radius: 4px; margin-bottom: 20px; font-size: 13px; }
    .btn-generate { background: #81b5a1; color: #fff; border: none; padding: 10px 24px; font-size: 14px; cursor: pointer; border-radius: 3px; }
    .btn-generate:hover { background: #6a9e8a; }
    .success { color: #2e7d32; font-size: 13px; margin-top: 14px; }
    .error { color: #c62828; font-size: 13px; margin-top: 14px; }
</style>
<h2>Export Check Results</h2>
<div class="info-box">
    <strong>Assessment Run:</strong> ${runNumber}<br/>
    <strong>Total Checks:</strong> ${totalChecks}
</div>
<p style="font-size:13px;color:#555;">Clicking Generate will create a CSV file and attach it to the assessment run record.</p>
<j:if test="${generated == 'true'}">
    <div class="success">&#10003; File generated: <strong>${fileName}</strong>. Check the Attachments on the assessment run record.</div>
</j:if>
<j:if test="${errorMsg != ''}">
    <div class="error">Error: ${errorMsg}</div>
</j:if>
<j:if test="${generated != 'true'}">
    <g:ui_form action="ui_page_process.do" id="assessment_export_form">
        <input type="hidden" name="sysparm_name" value="assessment_export"/>
        <input type="hidden" name="sysparm_run_id" value="${runId}"/>
        <input type="hidden" name="sysparm_action" value="generate"/>
        <button type="submit" class="btn-generate">Generate CSV File</button>
    </g:ui_form>
</j:if>
</j:jelly>
]]></html>
        <name>assessment_export</name>
        <processing_script><![CDATA[var action = RP.getParameterValue("sysparm_action");
if (action == "generate") {
    var runId = RP.getParameterValue("sysparm_run_id");
    var exporter = new x_snc_airop.AROPExporter();
    var result = exporter.generateExportCSV(runId);
    if (result.success) {
        RP.setRedirectURL("assessment_export.do?sysparm_run_id=" + runId + "&generated=true&file_name=" + encodeURIComponent(result.file_name));
    } else {
        RP.setRedirectURL("assessment_export.do?sysparm_run_id=" + runId + "&error_msg=" + encodeURIComponent(result.message));
    }
}
]]></processing_script>
