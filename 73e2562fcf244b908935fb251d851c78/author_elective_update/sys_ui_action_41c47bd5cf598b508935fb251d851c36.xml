        <active>true</active>
        <client>true</client>
        <client_script_v2><![CDATA[var confirmed = window.confirm('WARNING: This will DELETE all existing AIROP check definitions and re-seed them from the default set.\n\nAny custom check scripts will be lost.\n\nAre you sure you want to continue?');
if (confirmed) {
    gsftSubmit(null, g_form.getFormElement(), 'run_airop_installer');
    g_form.addInfoMessage('AIROP Installer is running... this may take 30-60 seconds.');
    return false;
}
return false;]]></client_script_v2>
