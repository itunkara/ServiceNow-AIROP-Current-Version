        <name>Run Installer</name>
        <onclick>return false;</onclick>
        <order>100</order>
        <script><![CDATA[(function runInstaller() {
    var confirmed = action.getGlideURI().get('sysparm_confirmed');
    if (confirmed !== 'true') {
        // Should not reach here if confirmation is handled client-side
        gs.addErrorMessage('Installation cancelled.');
        return;
    }

    try {
        var installer = new AROPInstaller();
        var log = installer.install();

        var runGr = new GlideRecord('x_snc_airop_assessment_run');
        if (runGr.get(current.getUniqueValue())) {
            runGr.assessment_log = '=== AIROP Installer Run at ' + new GlideDateTime().getDisplayValue() + ' ===\n' + log;
            runGr.update();
        }

        gs.addInfoMessage('AIROP Installer completed. Check the assessment log for details.');
    } catch(e) {
        gs.addErrorMessage('AIROP Installer failed: ' + e.message);
        gs.error('RunInstaller UI Action error: ' + e.message);
    }
})();]]></script>
