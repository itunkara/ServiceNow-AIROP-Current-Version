        <messages/>
        <name>Make Activities Scroll</name>
        <order/>
        <script><![CDATA[function onLoad() {
    // Wait for the DOM to fully load the activity stream
    setTimeout(function() {
        // Target the standard ServiceNow activity stream container element
        var activityContainer = document.querySelector('.activity-stream-container') || 
                                document.querySelector('.activity_stream_div') || 
                                document.getElementById('assessment_log');
        
        if (activityContainer) {
            // Set the maximum height you want before it starts scrolling
            activityContainer.style.maxHeight = "400px"; 
            activityContainer.style.overflowY = "auto";
            activityContainer.style.overflowX = "hidden";
            activityContainer.style.paddingRight = "10px"; // Prevents horizontal cut-offs
        }
    }, 1000); // 1-second delay ensures the activity stream elements are fully rendered
}
]]></script>
